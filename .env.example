# ---------------------------------------------------------------------------
# Collective Brain — environment configuration
# Copy to `.env` for local development. In Cloud Run, set these as service
# environment variables / secrets (do NOT commit real secrets).
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=8080
# Public base URL of the app (used to build the OAuth redirect + post-login redirect).
APP_BASE_URL=http://localhost:8080

# Database (Cloud SQL compatible). For Cloud SQL via socket use:
#   postgresql://USER:PASS@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://collective:collective@localhost:5432/collective?schema=public

# Session signing secret (JWT in an HTTP-only cookie). Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
# Cookie security: "auto" => secure cookies when NODE_ENV=production. Force with true/false.
COOKIE_SECURE=auto
# Session lifetime in days.
SESSION_TTL_DAYS=7

# Google OAuth 2.0 (consent screen set to "Internal")
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match an Authorized redirect URI on the OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Access control: only these Google Workspace domain(s) may sign in (comma-separated).
ALLOWED_DOMAINS=monks.com
# Comma-separated emails that are granted ADMIN on first login / via seed.
ADMIN_EMAILS=admin@monks.com

# Identity-Aware Proxy (production front door). When the Cloud Run service is
# fronted by IAP, set IAP_ENABLED=true so the app trusts IAP's verified identity
# (single sign-on, no second OAuth handshake). Leave false for local development.
IAP_ENABLED=false
# Optional: fully verify the IAP JWT assertion against this audience. Empty =
# trust the IAP identity header (safe because only IAP can invoke the service).
IAP_AUDIENCE=

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# File storage: "local" (dev) or "gcs" (production)
STORAGE_DRIVER=local
# local driver
LOCAL_STORAGE_DIR=./data/uploads
# gcs driver (uses Application Default Credentials in Cloud Run)
GCS_BUCKET=
GCS_PROJECT_ID=

# Uploads
MAX_UPLOAD_MB=20

# Translation tool provider: "mock" (fake, dev) | "pathways" (Monksflow Pathways trigger —
# whitelisted) | "lazarus" (Google Localizer API — needs Google allow-listing).
TRANSLATE_PROVIDER=mock
LOCALIZER_ENDPOINT=https://localizer.googleapis.com
# Privilege-bearing (allowlisted) service account email to impersonate for the
# https://www.googleapis.com/auth/localizationpartner scope. Required for lazarus.
LOCALIZER_PRINCIPAL=
# Default content type: CONTENT_TYPE_UI|MARKETING|LEGAL|API_TECHNICAL|HELP_CENTER|OTHER
LOCALIZER_DEFAULT_CONTENT_TYPE=CONTENT_TYPE_UI
# Optional Google product name (from GET /v1/products).
LOCALIZER_PRODUCT=
# Gemini model used for char-limit / glossary-aware variants.
TRANSLATE_FIT_MODEL=gemini-2.5-flash-lite

# Monksflow Pathways (whitelisted translation trigger). Required when TRANSLATE_PROVIDER=pathways.
# Store PATHWAYS_API_KEY in Secret Manager in production (never commit it).
PATHWAYS_TRIGGER_URL=
PATHWAYS_API_KEY=
